{
  "name": "qrcode-extension",
  "description": "web app for scanning and generating QR codes",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "compile": "tsc --noEmit",
    "lint": "oxlint --fix",
    "format": "oxfmt src vite.config.ts"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.6.1",
    "@types/qrcode": "^1.5.6",
    "daisyui": "^5.5.19",
    "oxfmt": "^0.1.0",
    "oxlint": "^1.2.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "wrangler": "4.78.0"
  },
  "dependencies": {
    "@zxing/library": "^0.21.3",
    "qrcode": "^1.5.4"
  }
