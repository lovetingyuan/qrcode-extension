{
  "name": "qrcode-extension",
  "description": "scan qrcode and generate qrcode",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:web": "vite --config vite.web.config.ts",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:web": "vite build --config vite.web.config.ts",
    "deploy": "npm run build:web && wrangler deploy",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "lint": "oxlint --fix",
    "format": "oxfmt entrypoints components assets",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/qrcode": "^1.5.6",
    "daisyui": "^5.5.19",
    "oxfmt": "^0.1.0",
    "oxlint": "^1.2.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "wrangler": "4.78.0",
    "wxt": "^0.20.20"
  },
  "dependencies": {
    "@zxing/library": "^0.21.3",
    "qrcode": "^1.5.4"
  }
}
